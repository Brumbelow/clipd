# Cargo build output
/target/

# Cargo lockfile is committed for binaries (kept by default).
# If this becomes a library, uncomment:
# Cargo.lock

# Editor / OS cruft
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Local env / secrets
.env
.env.local
*.pem
*.key

# clipd runtime data — never commit a real user's clipboard DB
**/entries.db
**/entries.db-*
**/key.dpapi

# Code-signing local state — Azure Trusted Signing config + any PFX/cert
signing/
*.pfx

# Release packaging artifacts (staging dir + zip produced by manual release flow)
clipd-v*-x86_64-pc-windows-msvc/
clipd-v*-x86_64-pc-windows-msvc.zip
